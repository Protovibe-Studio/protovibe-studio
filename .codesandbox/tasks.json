{
  "setupTasks": [
    {
      "name": "Install pnpm",
      "command": "npm install -g pnpm@9.15.9"
    },
    {
      "name": "Install template dependencies",
      "command": "pnpm --dir protovibe-project-template install"
    }
  ],
  "tasks": {
    "dev": {
      "name": "Run Protovibe template",
      "command": "pnpm --dir protovibe-project-template dev",
      "runAtStart": true,
      "preview": {
        "port": 3000
      }
    }
  }
}
